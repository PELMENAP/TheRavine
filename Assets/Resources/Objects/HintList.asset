  groups:
  - category: 0
    icon: {fileID: -1263307566, guid: 7c2a870de4fe8c8a6824b4d14f9c7496, type: 3}
    hints:
    - "\u041B\u044E\u0431\u0430\u044F \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430
      \u0440\u0435\u0448\u0430\u0435\u0442\u0441\u044F\u2026 \u0435\u0441\u043B\u0438
      \u0431\u0435\u0433\u0430\u0442\u044C \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
      \u0431\u044B\u0441\u0442\u0440\u043E"
    - "\u041A\u0440\u0430\u0441\u0438\u0432\u043E \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u0442\u044C
      - \u0442\u043E\u0436\u0435 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044F"
    - "\u0415\u0441\u043B\u0438 \u0432\u0441\u0451 \u0438\u0434\u0451\u0442 \u043F\u043E
      \u043F\u043B\u0430\u043D\u0443 \u2014 \u0437\u043D\u0430\u0447\u0438\u0442
      \u0442\u044B \u0447\u0442\u043E-\u0442\u043E \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B"
    - "\u0415\u0441\u043B\u0438 \u0432\u044B \u0434\u043E\u043B\u0433\u043E \u0441\u043C\u043E\u0442\u0440\u0438\u0442\u0435
      \u0432 \u0431\u0435\u0437\u0434\u043D\u0443 \u0442\u0435\u043A\u0441\u0442\u0443\u0440,
      \u0431\u0435\u0437\u0434\u043D\u0430 \u043D\u0430\u0447\u0438\u043D\u0430\u0435\u0442
      \u043F\u043E\u0434\u0433\u0440\u0443\u0436\u0430\u0442\u044C LOD-\u044B."
    - "\u0413\u0435\u0440\u043E\u0438\u0437\u043C \u2014 \u044D\u0442\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E
      \u043F\u0440\u044F\u0442\u0430\u0442\u044C\u0441\u044F \u0437\u0430 \u0443\u043A\u0440\u044B\u0442\u0438\u0435\u043C,
      \u043F\u043E\u043A\u0430 \u043D\u0435 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F."
  - category: 1
    icon: {fileID: -458490735, guid: 7c2a870de4fe8c8a6824b4d14f9c7496, type: 3}
    hints:
    - "\u0422\u044B \u043D\u0435 \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u043B\u0441\u044F.
      \u0422\u044B \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0441\u044F"
    - "\u041D\u0435 \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u0441\u044C
      \u043A \u0441\u043B\u0430\u0432\u0435 \u0438 \u0434\u0435\u043D\u044C\u0433\u0430\u043C,
      \u0441\u0442\u0440\u0435\u043C\u0438\u0442\u0435\u0441\u044C \u043A \u043F\u043E\u043F\u0443\u043B\u044F\u0440\u043D\u043E\u0441\u0442\u0438
      \u0438 \u0431\u043E\u0433\u0430\u0442\u0441\u0442\u0432\u0443"
    - "\u0421\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C \u2014
      \u044D\u0442\u043E \u043F\u0440\u043E\u0441\u0442\u043E \u0437\u0430\u043A\u043E\u043D\u043E\u043C\u0435\u0440\u043D\u043E\u0441\u0442\u044C,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u0442\u044B \u0435\u0449\u0451
      \u043D\u0435 \u043F\u043E\u043D\u044F\u043B"
    - "\xAB\u0422\u043E, \u0447\u0442\u043E \u043D\u0430\u0441 \u043D\u0435 \u0443\u0431\u0438\u0432\u0430\u0435\u0442,
      \u0434\u0435\u043B\u0430\u0435\u0442 \u043D\u0430\u0441 \u0441\u0438\u043B\u044C\u043D\u0435\u0435\xBB.
      \u0418 \u0437\u0430\u043E\u0434\u043D\u043E \u0434\u0430\u0435\u0442 \u043D\u0435\u043C\u043D\u043E\u0433\u043E
      \u043E\u043F\u044B\u0442\u0430 \u0434\u043B\u044F \u043F\u0440\u043E\u043A\u0430\u0447\u043A\u0438."
    - "\u0412\u0441\u044F\u043A\u0430\u044F \u043A\u0440\u0430\u0441\u043E\u0442\u0430
      \u043D\u0435\u0434\u043E\u043B\u0433\u043E\u0432\u0435\u0447\u043D\u0430. \u041A\u0430\u043A
      \u0438 \u0432\u0430\u0448\u0438 \u0431\u0430\u0444\u0444\u044B \u043E\u0442
      \u0437\u0435\u043B\u0438\u0439"
  - category: 2
    icon: {fileID: -581719678, guid: 7c2a870de4fe8c8a6824b4d14f9c7496, type: 3}
    hints:
    - "\u0415\u0441\u043B\u0438 \u0432\u0440\u0430\u0433 \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0441\u0438\u043B\u044C\u043D\u044B\u043C
      \u2014 \u043F\u043E\u0437\u0434\u0440\u0430\u0432\u043B\u044F\u044E, \u0442\u044B
      \u043D\u0430\u0448\u0451\u043B \u043A\u043E\u043D\u0442\u0435\u043D\u0442 \u043D\u0430
      \u043F\u043E\u0442\u043E\u043C"
    - "\u0415\u0441\u043B\u0438 \u0431\u043E\u0441\u0441 \u0437\u0430\u0441\u0442\u0440\u044F\u043B
      \u0433\u043E\u043B\u043E\u0432\u043E\u0439 \u0432 \u0441\u0442\u0435\u043D\u0435,
      \u043F\u0440\u043E\u044F\u0432\u0438\u0442\u0435 \u0441\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u0438\u0435"
    - "\u041D\u0430\u0448\u0438 NPC \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
      \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u044B\u0435 \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u043D\u044B\u0435
      \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u044B \u0418\u0418.
      \u0415\u0441\u043B\u0438 \u043E\u043D\u0438 \u0445\u0430\u043E\u0442\u0438\u0447\u043D\u043E
      \u0431\u0435\u0433\u0430\u044E\u0442 \u043A\u0440\u0443\u0433\u0430\u043C\u0438,
      \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0438\u0445 \u043D\u0435\u0439\u0440\u043E\u0441\u0435\u0442\u044C
      \u043F\u0440\u043E\u0441\u0442\u043E... \u043D\u0435\u043C\u043D\u043E\u0433\u043E
      \u043F\u0440\u043E\u0442\u0435\u043A\u043B\u0430."
    - "\u042D\u0442\u043E\u0442 \u043C\u0438\u0440 \u0441\u043E\u0437\u0434\u0430\u0435\u0442\u0441\u044F
      \u043D\u0430 \u043B\u0435\u0442\u0443. \u0415\u0441\u043B\u0438 \u0432\u0430\u043C
      \u043A\u0430\u0442\u0435\u0433\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u0438
      \u043D\u0435 \u043D\u0440\u0430\u0432\u0438\u0442\u0441\u044F \u043F\u0435\u0439\u0437\u0430\u0436
      \u2014 \u0432\u0441\u0435 \u043F\u0440\u0435\u0442\u0435\u043D\u0437\u0438\u0438
      \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u044F\u0439\u0442\u0435 \u0433\u0435\u043D\u0435\u0440\u0430\u0442\u043E\u0440\u0443
      \u043F\u0441\u0435\u0432\u0434\u043E\u0441\u043B\u0443\u0447\u0430\u0439\u043D\u044B\u0445
      \u0447\u0438\u0441\u0435\u043B."
    - "\u0412\u0430\u0448 \u0440\u044E\u043A\u0437\u0430\u043A \u043D\u0430\u0440\u0443\u0448\u0430\u0435\u0442
      \u0432\u0441\u0435 \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0435 \u0437\u0430\u043A\u043E\u043D\u044B
      \u0442\u043E\u043F\u043E\u043B\u043E\u0433\u0438\u0438 \u0438 \u0435\u0432\u043A\u043B\u0438\u0434\u043E\u0432\u043E\u0439
      \u0433\u0435\u043E\u043C\u0435\u0442\u0440\u0438\u0438"
    - "\u0411\u044B\u0441\u0442\u0440\u043E\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u0435
      \u044D\u043A\u043E\u043D\u043E\u043C\u0438\u0442 \u0432\u0440\u0435\u043C\u044F,
      \u043D\u043E \u043B\u0438\u0448\u0430\u0435\u0442 \u0432\u0430\u0441 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
      \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u0438 \u043F\u043E\u0442\u0435\u0440\u044F\u0442\u044C\u0441\u044F
      \u043F\u043E \u043F\u0443\u0442\u0438"
  - category: 3
    icon: {fileID: 905921577, guid: 7c2a870de4fe8c8a6824b4d14f9c7496, type: 3}
    hints:
    - "\u0414\u043B\u044F \u043E\u043F\u0442\u0438\u043C\u0438\u0437\u0430\u0446\u0438\u0438
      \u043D\u0430\u0436\u043C\u0438\u0442\u0435 Alt + F4. \u0414\u043B\u044F \u0434\u0443\u0445\u043E\u0432\u043D\u043E\u0433\u043E
      \u043F\u0440\u043E\u0441\u0432\u0435\u0442\u043B\u0435\u043D\u0438\u044F \u2014
      \u0432\u044B\u0439\u0434\u0438\u0442\u0435 \u043D\u0430 \u0443\u043B\u0438\u0446\u0443
      \u0438 \u043F\u043E\u0442\u0440\u043E\u0433\u0430\u0439\u0442\u0435 \u0442\u0440\u0430\u0432\u0443"
    - "\u0415\u0441\u043B\u0438 \u0434\u043E\u043B\u0433\u043E \u043D\u0435 \u0441\u043F\u0430\u0442\u044C,
      \u043C\u043E\u0436\u043D\u043E \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
      The Ravine"
    - "\u0415\u0441\u043B\u0438 \u0434\u043E\u043B\u0433\u043E \u0441\u043F\u0430\u0442\u044C,
      \u043C\u043E\u0436\u043D\u043E \u0438 \u043F\u0440\u043E\u0441\u043F\u0430\u0442\u044C"
    - "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u043D\u0435 \u0441\u043B\u043E\u043C\u0430\u043D\u0430.
      \u041E\u043D\u0430 \u043F\u0440\u043E\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
      \u0432 \u0441\u043E\u0441\u0442\u043E\u044F\u043D\u0438\u0438, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
      \u0442\u044B \u0435\u0449\u0451 \u043D\u0435 \u043F\u043E\u043D\u044F\u043B"
    - "\u0418\u043D\u043E\u0433\u0434\u0430 \u043B\u0443\u0447\u0448\u0438\u0439
      \u0431\u0438\u043B\u0434 \u2014 \u0442\u043E\u0442, \u043A\u043E\u0442\u043E\u0440\u044B\u0439
      \u043D\u043E\u0432\u0430\u044F \u0432\u0435\u0440\u0441\u0438\u044F"
    - "\u041D\u0435 \u0437\u0430\u0431\u044B\u0432\u0430\u0439\u0442\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0442\u044C\u0441\u044F.
      \u0418\u043D\u0430\u0447\u0435 \u0441\u0431\u043E\u0440\u0449\u0438\u043A \u043C\u0443\u0441\u043E\u0440\u0430
      C# \u0443\u0434\u0430\u043B\u0438\u0442 \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
      \u0431\u0435\u0441\u0445\u043E\u0437\u043D\u044B\u0435 \u043E\u0431\u044A\u0435\u043A\u0442\u044B,
      \u043D\u043E \u0438 \u0432\u0430\u0448\u0438 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
      \u0442\u0440\u0438 \u0447\u0430\u0441\u0430 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u043E\u0433\u043E
      \u043F\u0440\u043E\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F."
    - "\u0415\u0441\u043B\u0438 \u0432\u044B \u0432\u0438\u0434\u0438\u0442\u0435
      \u044D\u0442\u043E\u0442 \u0442\u0435\u043A\u0441\u0442, \u0437\u043D\u0430\u0447\u0438\u0442,
      \u043D\u0430\u0448 \u0445\u0432\u0430\u043B\u0435\u043D\u044B\u0439 \u0430\u043B\u0433\u043E\u0440\u0438\u0442\u043C
      \u043F\u0440\u0435\u0434\u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0438 \u0430\u0441\u0441\u0435\u0442\u043E\u0432
      \u043E\u043F\u044F\u0442\u044C \u043D\u0435 \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u043B"
    - "\u041F\u0440\u0438 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0435
      \u0438\u0433\u0440\u044B \u043D\u0435 \u043F\u043E\u0441\u0442\u0440\u0430\u0434\u0430\u043B\u043E
      \u043D\u0438 \u043E\u0434\u043D\u043E \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435,
      \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0430\u0440\u0430 \u043A\u043B\u0430\u0432\u0438\u0430\u0442\u0443\u0440"
    - "\u041C\u044B \u0445\u043E\u0442\u0435\u043B\u0438 \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
      \u0441\u044E\u0434\u0430 \u0446\u0438\u0442\u0430\u0442\u0443 \u0428\u0435\u043A\u0441\u043F\u0438\u0440\u0430,
      \u043D\u043E \u0440\u0435\u0448\u0438\u043B\u0438, \u0447\u0442\u043E \u0448\u0443\u0442\u043A\u0430
      \u043F\u0440\u043E \u0431\u0430\u0433\u0438 \u0431\u0443\u0434\u0435\u0442
      \u0436\u0438\u0437\u043D\u0435\u043D\u043D\u0435\u0435"
    - "\u041C\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C
      \u043F\u0435\u0440\u0435\u0434\u043E\u0432\u044B\u0435 \u0418\u0418-\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u044B.
      \u041F\u043E\u044D\u0442\u043E\u043C\u0443, \u0435\u0441\u043B\u0438 \u0431\u043E\u0441\u0441
      \u043F\u043E\u0431\u0435\u0436\u0434\u0430\u0435\u0442, \u044D\u0442\u043E
      \u043D\u0435 \u0441\u043A\u0440\u0438\u043F\u0442 \u2014 \u0432\u044B \u043F\u0440\u043E\u0441\u0442\u043E
      \u043B\u043E\u0445"
